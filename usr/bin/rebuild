#!/bin/sh

CHADWM_DIR="$HOME/.config/ohmychadwm/chadwm"

if [ ! -d "$CHADWM_DIR" ]; then
    echo "Directory $CHADWM_DIR not found."
    exit 1
fi

cd "$CHADWM_DIR" || exit 1

read -rp "Do you want to edit config.def.h before rebuilding? [y/N] " answer
case "$answer" in
    [yY]|[yY][eE][sS])
        nano config.def.h
        ;;
esac

./rebuild.sh